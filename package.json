{
  "name": "mac-graph",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run --passWithNoTests --exclude tests/e2e",
    "test:watch": "vitest --passWithNoTests --exclude tests/e2e",
    "test:e2e": "E2E=1 vitest run tests/e2e",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t mac-graph:latest .",
    "docker:run": "scripts/docker-run.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^11.5.0",
    "hono": "^4.6.0",
    "ignore": "^6.0.0",
    "kuzu": "^0.11.0",
    "pino": "^9.5.0",
    "tree-sitter": "^0.22.0",
    "tree-sitter-css": "^0.23.0",
    "tree-sitter-html": "^0.23.0",
    "tree-sitter-json": "^0.24.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@sourcegraph/scip-typescript": "^0.4.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "dockerode": "^4.0.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
